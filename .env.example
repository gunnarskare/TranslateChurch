OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSLATION_MODEL=gpt-4o-mini

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*

# Audio capture settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_DTYPE=float32
AUDIO_BLOCK_DURATION_MS=100
# Prefer one of these if the default input device is not your USB mixer.
AUDIO_DEVICE_INDEX=
AUDIO_DEVICE_NAME=

# Simple energy-based VAD tuning
VAD_ENERGY_THRESHOLD=0.015
VAD_SILENCE_TIMEOUT_SECONDS=1.0
VAD_MINIMUM_SPEECH_SECONDS=0.7
MAXIMUM_SEGMENT_SECONDS=30
MINIMUM_TRANSCRIPT_CHARACTERS=3

# Set true to disable live microphone capture and use /api/test/segment instead.
TEST_MODE=false
